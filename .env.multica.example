#ddev-generated
# Multica daemon configuration (optional).
#
# Multica (https://multica.ai) is a managed-agents platform that delegates
# tasks to AI coding agent CLIs running locally. When this file contains a
# valid MULTICA_TOKEN, every DDEV add-on that ships a Multica-compatible AI
# agent (Claude Code, OpenCode, ...) will start a daemon inside its
# container, register with your self-hosted Multica server, and become
# available to receive tasks from the Multica UI.
#
# This file is shared by ALL Multica-aware DDEV add-ons. A single
# configuration enables the daemon in every container that supports it.
#
# Two locations are supported (per-project overrides global):
#   1. .ddev/.env.multica           — per-project (this project only)
#   2. ~/.ddev/multica/.env.multica — global (all projects, default)
#
# To activate Multica globally (recommended):
#   1. Copy this file to ~/.ddev/multica/.env.multica
#   2. Fill in the three values below.
#   3. ddev restart (in any project using a Multica-aware add-on).
#
# To override per project:
#   1. Copy this file to .ddev/.env.multica (in the project root).
#   2. Fill in the values (different token, server, etc.).
#   3. ddev restart. The container will use the project file instead of the global one.
#
# To disable Multica: empty MULTICA_TOKEN (or delete both files) and
# ddev restart. The containers will run normally without the daemon.

# WebSocket URL of your self-hosted Multica backend.
# Example: wss://multica.example.com/ws
MULTICA_SERVER_URL=wss://multica.example.com/ws

# HTTPS URL of your self-hosted Multica frontend.
# Example: https://multica.example.com
MULTICA_APP_URL=https://multica.example.com

# Personal Access Token from your Multica UI:
#   Settings -> Personal Access Tokens -> New token
# The token is shown only once and starts with "mul_".
# Default expiry is 90 days (regenerate before expiry to avoid downtime).
MULTICA_TOKEN=

# ---------------------------------------------------------------------------
# Human token-usage tracking (Atlas extension — NOT part of Multica)
# ---------------------------------------------------------------------------
# Optional. When set, token usage from HUMAN interactive `claude` / `opencode`
# sessions (a person working directly in the container, not the daemon running
# a task) is forwarded to your server and attributed to the SAME runtime the
# daemon registers. Daemon-run tasks are NOT forwarded here, so they are never
# double-counted (the daemon already reports them via its own API).
#
# Requires the daemon to be active (MULTICA_TOKEN + the two URLs above set),
# because the runtime identity comes from the daemon registration. Leave empty
# to disable (default) — behaviour is then identical to before.
#
# Use your server's API token. In the typical single-server setup this is the
# SAME value as MULTICA_TOKEN above (everything goes to one server).
ATLAS_HUMAN_USAGE_TOKEN=

# Optional. OTLP collector base URL on your server. Defaults to
# ${MULTICA_APP_URL}/api/usage — metrics are POSTed to <base>/v1/metrics as
# OTLP/HTTP JSON with an "Authorization: Bearer <token>" header. Override only
# if your server exposes the receiver elsewhere.
#ATLAS_USAGE_ENDPOINT=

# Optional. Metric export interval in milliseconds (default 10000). Lower =
# less data lost when a very short session exits between exports; higher =
# fewer requests.
#ATLAS_USAGE_INTERVAL=
