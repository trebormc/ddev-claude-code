#ddev-generated
# Claude Code AI container for DDEV
# Ubuntu 24.04 + Node.js 22 + Claude Code CLI + Docker CLI

FROM ubuntu:24.04

ARG USERNAME=claude
ARG USER_UID=1000
ARG USER_GID=1000

ENV DEBIAN_FRONTEND=noninteractive
ENV USERNAME=${USERNAME}
ENV USER_HOME=/home/${USERNAME}

# Install base dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    git \
    ca-certificates \
    gnupg \
    sudo \
    ripgrep \
    fd-find \
    jq \
    vim \
    less \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22 (required by Claude Code)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Create user with matching UID/GID from host
RUN existing_user=$(getent passwd ${USER_UID} | cut -d: -f1) \
    && existing_group=$(getent group ${USER_GID} | cut -d: -f1) \
    && if [ -n "$existing_user" ] && [ "$existing_user" != "${USERNAME}" ]; then \
         userdel -r $existing_user 2>/dev/null || true; \
       fi \
    && if [ -n "$existing_group" ] && [ "$existing_group" != "${USERNAME}" ]; then \
         groupdel $existing_group 2>/dev/null || true; \
       fi \
    && groupadd --gid ${USER_GID} ${USERNAME} 2>/dev/null || true \
    && useradd --uid ${USER_UID} --gid ${USER_GID} -m -s /bin/bash ${USERNAME} 2>/dev/null || true \
    && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/${USERNAME} \
    && chmod 0440 /etc/sudoers.d/${USERNAME}

# Add user to docker group
RUN usermod -aG docker ${USERNAME} || true

# Install bd wrapper — delegates to Beads container via docker exec
RUN printf '#!/bin/bash\nexec docker exec -i "$BEADS_CONTAINER" bd "$@"\n' > /usr/local/bin/bd \
    && chmod +x /usr/local/bin/bd

# Create required directories
RUN mkdir -p ${USER_HOME}/.claude \
    && mkdir -p ${USER_HOME}/.npm-global \
    && mkdir -p /var/www/html \
    && chown -R ${USER_UID}:${USER_GID} ${USER_HOME} \
    && chown -R ${USER_UID}:${USER_GID} /var/www/html

USER ${USERNAME}
WORKDIR ${USER_HOME}

# Configure npm global packages in user home
ENV NPM_CONFIG_PREFIX=${USER_HOME}/.npm-global
ENV PATH="${USER_HOME}/.npm-global/bin:${PATH}"

# Install Claude Code globally
RUN npm install -g @anthropic-ai/claude-code@latest

# Create useful aliases and helper functions
RUN echo 'export PATH="${HOME}/.npm-global/bin:${PATH}"' >> ~/.bashrc \
    && echo 'alias ll="ls -la"' >> ~/.bashrc \
    && echo '' >> ~/.bashrc \
    && echo '# Helper function to execute in web container (detects TTY)' >> ~/.bashrc \
    && echo 'web-exec() { if [ -t 0 ]; then docker exec -it "$WEB_CONTAINER" "$@"; else docker exec -i "$WEB_CONTAINER" "$@"; fi; }' >> ~/.bashrc \
    && echo 'drush() { web-exec ./vendor/bin/drush "$@"; }' >> ~/.bashrc \
    && echo 'composer() { web-exec composer "$@"; }' >> ~/.bashrc \
    && echo 'phpunit() { web-exec ./vendor/bin/phpunit "$@"; }' >> ~/.bashrc \
    && echo 'phpstan() { web-exec ./vendor/bin/phpstan "$@"; }' >> ~/.bashrc \
    && echo 'web-shell() { docker exec -it "$WEB_CONTAINER" bash; }' >> ~/.bashrc \
    && echo '' >> ~/.bashrc \
    && echo 'echo "Claude Code container ready"' >> ~/.bashrc \
    && echo 'echo "   Web container: \$WEB_CONTAINER"' >> ~/.bashrc \
    && echo 'echo "   Site URL: \$DDEV_PRIMARY_URL"' >> ~/.bashrc \
    && echo 'echo ""' >> ~/.bashrc \
    && echo 'echo "Commands: claude | drush | phpunit | phpstan | web-shell | bd"' >> ~/.bashrc \
    && echo '' >> ~/.bashrc

# Create entrypoint script that sets up agents and skills before running the main command
RUN cat > /usr/local/bin/entrypoint.sh << 'ENTRY'
#!/bin/bash

# Set up agents, skills, and config from synced Claude Code volume
if [ -d "/agents-claude" ]; then
  mkdir -p /var/www/html/.claude

  # Symlink agents to .claude/agents/
  [ -d "/agents-claude/agent" ] && ln -sfn /agents-claude/agent /var/www/html/.claude/agents

  # Symlink skills to .claude/skills/ (both Claude Code and OpenCode discover this path)
  [ -d "/agents-claude/skills" ] && ln -sfn /agents-claude/skills /var/www/html/.claude/skills

  # Symlink rules to .claude/rules/
  [ -d "/agents-claude/rules" ] && ln -sfn /agents-claude/rules /var/www/html/.claude/rules

  # Copy CLAUDE.md to project root if not already present
  if [ ! -f "/var/www/html/CLAUDE.md" ] && [ -f "/agents-claude/CLAUDE.md" ]; then
    cp /agents-claude/CLAUDE.md /var/www/html/CLAUDE.md 2>/dev/null || true
  fi
fi

exec "$@"
ENTRY
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

WORKDIR /var/www/html
